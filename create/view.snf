# https://www.postgresql.org/docs/18/sql-createview.html

CREATE [ OR REPLACE ] [ TEMPORARY | TEMP ] [ RECURSIVE ] VIEW name [ ( colname [, ...] ) ]
    [ WITH ( { view_parameter [= value] } [, ...] ) ]
    AS select_statement
    [ check_option ]

# WHERE check_option
WITH [ CASCADED | LOCAL ] CHECK OPTION

# STATEMEMT select_statement
SELECT
TABLE
VALUES
