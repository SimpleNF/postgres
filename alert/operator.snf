# https://www.postgresql.org/docs/18/sql-alteroperator.html

ALTER OPERATOR name ( { left | NONE }, right ) SET (
    [ RESTRICT = { restrict | NONE }, ]
    [ JOIN = { join | NONE }, ]
    [ COMMUTATOR = commutator, ]
    [ NEGATOR = negator, ]
    [ HASHES, ]
    [ MERGES, ]
)

ALTER OPERATOR name ( { left | NONE }, right ) OWNER TO role

ALTER OPERATOR name ( { left | NONE }, right ) SET SCHEMA schema

# WHERE role
{ role_name | CURRENT_ROLE | CURRENT_USER | SESSION_USER }
