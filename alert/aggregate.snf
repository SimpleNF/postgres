# https://www.postgresql.org/docs/18/sql-alteraggregate.html

ALTER AGGREGATE name ( signature ) RENAME TO new_name

ALTER AGGREGATE name ( signature ) OWNER TO role

ALTER AGGREGATE name ( signature ) SET SCHEMA schema

# WHERE signature
* | arg [, ...] | arg [, ...] ORDER BY order [, ...]

# WHERE arg, order
[ argmode ] [ argname ] argtype

# WHERE role
{ role_name | CURRENT_ROLE | CURRENT_USER | SESSION_USER }
