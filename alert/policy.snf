# https://www.postgresql.org/docs/18/sql-alterpolicy.html

ALTER POLICY name ON table
    [ TO role_public [, ...] ]
    [ USING ( boolean_expression ) ]
    [ WITH CHECK ( boolean_expression ) ]

ALTER POLICY name ON table RENAME TO new_name

# WHERE role_public
name | CURRENT_ROLE | CURRENT_USER | SESSION_USER | PUBLIC
