# https://www.postgresql.org/docs/18/sql-reindex.html

REINDEX [ ( config ) ] { INDEX | TABLE | SCHEMA } [ CONCURRENTLY ] name

REINDEX [ ( config ) ] { DATABASE | SYSTEM } [ CONCURRENTLY ] [ name ]

# WHERE config
[ CONCURRENTLY [ concurrently ], ]
[ TABLESPACE tablespace, ]
[ VERBOSE [ verbose ], ]
